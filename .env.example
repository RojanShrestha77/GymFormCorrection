# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Security ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ────────────────────────────────────────────────────
# Local dev: use SQLite (no setup needed)
DATABASE_URL=sqlite:///./gymform.db
# Production / Docker: use PostgreSQL
# DATABASE_URL=postgresql://gymform:your_password@db:5432/gymform_db

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ── Email (for password reset — use a Gmail app password) ───────
# Generate app password: myaccount.google.com → Security → App passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
CLIENT_URL=http://localhost:3000

# ── App ─────────────────────────────────────────────────────────
ENVIRONMENT=development
